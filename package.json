{
  "name": "@bakissation/fastify-satim",
  "version": "1.1.0",
  "description": "Fastify plugin for the Satim (SATIM-IPAY) payment gateway SDK",
  "author": "Abdelbaki Berkati (@bakissation)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p test/tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "fastify",
    "fastify-plugin",
    "satim",
    "payment",
    "gateway",
    "algeria",
    "cib",
    "dzd",
    "e-commerce"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bakissation/fastify-satim"
  },
  "dependencies": {
    "@bakissation/satim": "^1.1.0",
    "@sinclair/typebox": "^0.34.46",
    "fastify-plugin": "^5.1.0"
  },
  "peerDependencies": {
    "fastify": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "fastify": "^4.28.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
